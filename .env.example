# ──────────────────────────────────────────────────────────────────
# .env.example  —  copy to .env and fill in your values
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────

# Application
APP_NAME="Adaptive Auth System"
ENVIRONMENT=development
DEBUG=False
ALLOWED_ORIGINS=http://localhost:8000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=adaptive_auth
DB_USER=root
DB_PASSWORD=root

# Redis  (leave REDIS_PASSWORD empty for local dev)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT  — generate a strong key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=8d2a8f7114fcce7900deebff48ead923f68d7d90cb4a52f9fad7a7790d67db89
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Account lockout
MAX_FAILED_LOGINS=5
LOCKOUT_DURATION_MINUTES=15

# Password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPER=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=True

# MFA
MFA_CHALLENGE_TTL_SECONDS=300
MFA_MAX_ACTIVE_CHALLENGES=3

# Behaviour windows (seconds)
MFA_WINDOW_SECONDS=120
LOGIN_WINDOW_SECONDS=300
APPROVAL_WINDOW_SECONDS=120

# Behaviour trigger limits
MFA_REQUEST_LIMIT=3
LOGIN_ATTEMPT_LIMIT=5
APPROVAL_LIMIT=3

# Risk score weights
WEIGHT_EXCESS_MFA=30
WEIGHT_RAPID_LOGIN=20
WEIGHT_REPEATED_APPROVALS=25
WEIGHT_NEW_DEVICE=20
WEIGHT_IP_CHANGE=15
WEIGHT_IMPOSSIBLE_TRAVEL=40
WEIGHT_OFF_HOURS=10

# Decision thresholds
THRESHOLD_ALLOW=39
THRESHOLD_VERIFY=69

# Rate limits (SlowAPI format)
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_MFA=20/minute

# Off-hours detection (UTC hours)
OFF_HOURS_START=22
OFF_HOURS_END=6
